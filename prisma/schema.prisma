generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LocationType {
  REMOTE
  HYBRID
  ONSITE
}

model Company {
  id            String         @id @default(cuid())
  name          String
  website       String?
  careerPage    String?
  logo          String?
  size          String?
  domain        String?
  jobs          Job[]
  scraperConfig ScraperConfig?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Job {
  id             String       @id @default(cuid())
  title          String
  company        Company      @relation(fields: [companyId], references: [id])
  companyId      String
  description    String
  rawDescription Json?
  url            String       @unique
  source         String
  location       String?
  locationType   LocationType
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?
  experienceMin  Int?
  experienceMax  Int?
  stack          String[]
  stackRaw       String?
  seniorityLevel String?
  relevanceScore Float?
  fingerprint    String       @unique
  postedAt       DateTime?
  scrapedAt      DateTime     @default(now())
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([source])
  @@index([postedAt])
  @@index([isActive])
  @@index([stack], type: Gin)
}

model ScraperConfig {
  id              String    @id @default(cuid())
  company         Company   @relation(fields: [companyId], references: [id])
  companyId       String    @unique
  sourceType      String
  baseUrl         String
  selectors       Json
  paginationType  String?
  scheduleMinutes Int       @default(360)
  isActive        Boolean   @default(true)
  lastRunAt       DateTime?
  lastRunStatus   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model User {
  id               String         @id @default(cuid())
  telegramChatId   String         @unique
  telegramUsername String?
  stackPreferences String[]
  locationPrefs    String[]
  seniorityPref    String?
  minSalary        Int?
  isActive         Boolean        @default(true)
  subscriptions    Subscription[]
  alertsLog        AlertLog[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Subscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  frequency String   @default("daily")
  timeOfDay String?  @default("09:00")
  timezone  String?  @default("Asia/Kolkata")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlertLog {
  id      String   @id @default(cuid())
  user    User     @relation(fields: [userId], references: [id])
  userId  String
  jobId   String
  sentAt  DateTime @default(now())
  channel String
}
